{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileStorageConfig": {
    "LocalStorageRoot": "D:/Personal/Fugo/StorageRoot",
    "TitleHubDocRoot": "//10.0.9.6/TitleHubStorage"
  },
  "TitleHubApiConfig": {
    "BaseUrl": "https://localhost/titlehub",
    "RetryPolicy": {
      "TimeoutSeconds": 30,
      "Retry": {
        "MaxRetryAttempts": 1,
        "RetryDelay": "00:00:02"
      },
      "CircuitBreaker": {
        "SamplingDurationSeconds": 30,
        "FailureRatio": 0.1,
        "MinimumThroughput": 3,
        "BreakDurationSeconds": 5
      }
    }
  }
}
